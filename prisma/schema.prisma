generator client {
  provider = "prisma-client-js"
}

datasource db {
  provider = "sqlite"
  url      = env("DATABASE_URL")
}

model TargetDatabase {
  id        String   @id @default(cuid())
  name      String   @unique // ex: "X360C Local", "X360C VPS"
  url       String   // Caminho do arquivo dev.db ou URL do MySQL/Postgres
  isActive  Boolean  @default(true)
  createdAt DateTime @default(now())
  updatedAt DateTime @updatedAt
}

model User {
  id        String   @id @default(cuid())
  username  String   @unique
  password  String   // Hash da senha
  role      String   @default("USER") // ADMIN ou USER
  createdAt DateTime @default(now())
  updatedAt DateTime @updatedAt

  @@map("Admin")
}

// ============================================================
// Licenças do NEXUS 360 Desktop
// ============================================================
model DesktopLicense {
  id         String    @id @default(cuid())
  key        String    @unique // Ex: NEXUS-XXXX-XXXX-XXXX
  clientName String    // Nome do cliente
  email      String?   // E-mail do cliente
  plan       String    @default("STANDARD") // STANDARD, PRO, UNLIMITED
  machineId  String?   // Hash da máquina onde foi ativada
  isActive   Boolean   @default(true)
  expiresAt  DateTime? // null = vitalício
  createdAt  DateTime  @default(now())
  updatedAt  DateTime  @updatedAt
  lastSeenAt DateTime? // Última validação online
  notes      String?   // Observações internas
}
